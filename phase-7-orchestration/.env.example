# Copy to `.env` and fill in real values. Never commit `.env`.
#   cp .env.example .env

# --- LLM backends (set the one you use in config/settings.yaml) ---
# insights.backend / summarize.backend: deterministic | openai | groq

# Groq (https://console.groq.com) — recommended for fast, cheap generation
GROQ_API_KEY=

# OpenAI (https://platform.openai.com)
OPENAI_API_KEY=

# --- Reddit API (optional; needed when public reddit.com JSON is blocked) ---
# Create a "script" app at https://www.reddit.com/prefs/apps then:
# REDDIT_CLIENT_ID=
# REDDIT_CLIENT_SECRET=

# --- Email send gating (fail-safe: anything other than "send" → draft) ---
# EMAIL_MODE=draft
# EMAIL_MODE=send

# --- Optional Vercel auto-deploy from the weekly schedule ---
# PULSE_VERCEL_DEPLOY=1
# VERCEL_SCOPE=nikhilt27s-projects

# Community forum/social/product drops live under:
#   .pulse/community_drops/<product_id>/*.json
