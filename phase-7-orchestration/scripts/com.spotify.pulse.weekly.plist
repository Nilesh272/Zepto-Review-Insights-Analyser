    <key>StandardOutPath</key>
    <string>__PULSE_ROOT__/.pulse/logs/launchd-stdout.log</string>
    <key>StandardErrorPath</key>
    <string>__PULSE_ROOT__/.pulse/logs/launchd-stderr.log</string>
    <key>EnvironmentVariables</key>
